{
  "compilerOptions": {
    "target":                     "ES2020",
    "module":                     "CommonJS",
    "lib":                        ["ES2020"],
    "outDir":                     "./dist",
    "rootDir":                    "./src",
    "strict":                     true,
    "esModuleInterop":            true,
    "allowSyntheticDefaultImports": true,
    "downlevelIteration":         true,
    "skipLibCheck":               true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":          true,
    "moduleResolution":           "node"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
