    "@types/express":      "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node":         "^22.5.4",
    "@types/pg":           "^8.11.10",
    "ts-node-dev":         "^2.0.0",
    "typescript":          "^5.6.2"
