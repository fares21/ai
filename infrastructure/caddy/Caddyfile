{
    # On-Demand TLS: ask the backend before issuing any certificate
    on_demand_tls {
        ask      http://api:3000/api/internal/verify-domain
        interval 2m
        burst    5
    }
    email admin@monadim.online
}

# Wildcard subdomains (*.monadim.online)
*.monadim.online, monadim.online {
    reverse_proxy /api/*  api:3000
    reverse_proxy /tma/*  tma:80
    reverse_proxy         api:3000
}

# Custom domains for schools (auto SSL)
https:// {
    tls { on_demand }
    reverse_proxy /api/* api:3000
    reverse_proxy        tma:80
}
